# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/soconstrutoras

# JWT
JWT_SECRET=troque-por-uma-string-segura-de-pelo-menos-64-chars
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Storage (Cloudflare R2 ou AWS S3)
STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
STORAGE_BUCKET=soconstrutoras-midias
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=https://midias.soconstrutoras.com.br

# Pagamentos (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs dos planos — criar no Stripe Dashboard > Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFISSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# E-mail (para notificações de leads)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@soconstrutoras.com.br
